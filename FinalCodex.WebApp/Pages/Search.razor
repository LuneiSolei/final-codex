@page "/search"
@using FinalCodex.SharedLibrary
@using FinalCodex.SharedLibrary.Services
@using FinalCodex.WebApp.Components.Filters
@using MudBlazor
@inject CodexService CodexService;

<FiltersMenu />

<MudContainer Class="pa-8">
    <MudStack Spacing="8">
        @* SearchState Form *@
        <MudForm @ref="Form" OnEnterPressed="Submit">
            @* SearchStatebar *@
            <MudTextField @bind-Value="CodexService.SearchState.Query"
                          Adornment="Adornment.End"
                          AdornmentIcon="@GetFilterIcon()"
                          Class="mud-theme-dark"
                          Clearable="true"
                          For="@(() => CodexService.SearchState.Query)"
                          OnAdornmentClick="@ToggleSearchFilters"
                          Placeholder="SearchState"
                          ShrinkLabel="true"
                          Underline="false"
                          Variant="Variant.Outlined" />
        </MudForm>

        @* Results *@
        <MudPaper Class="pa-4">
            <MudText>Results go here</MudText>
        </MudPaper>
    </MudStack>
</MudContainer>