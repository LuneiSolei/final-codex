@using FinalCodex.SharedLibrary.Services
@using FinalCodex.WebApp.Components
@using MudBlazor
@inherits LayoutComponentBase
@inject CodexService CodexService;

<MudThemeProvider @bind-IsDarkMode="CodexService.AppState.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Fixed="false">
        <MudIconButton Edge="Edge.Start"
                       Size="Size.Large"
                       Icon="@Icons.Material.TwoTone.Menu"
                       Color="Color.Inherit"
                       OnClick="@ToggleNavMenu" />
        <MudSpacer />
        <ThemeModeToggle />
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub"
                       Color="Color.Inherit"
                       Edge="Edge.End" 
                       Href="https://github.com/luneisolei/final-codex"/>
    </MudAppBar>
    <NavMenu />
    <MudMainContent Class="pa-0">
        @Body
    </MudMainContent>
</MudLayout>