@using FinalCodex.Shared
@using FinalCodex.WebApp.Components
@using MudBlazor
@inherits LayoutComponentBase
@inject AppState AppState

<MudThemeProvider @bind-IsDarkMode="@AppState.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Fixed="false">
        <MudIconButton Edge="Edge.Start"
                       Size="Size.Large"
                       Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       OnClick="@AppState.ToggleNavMenu" />
        <MudSpacer />
        <ThemeModeToggle />
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub"
                       Color="Color.Inherit"
                       Edge="Edge.End" />
    </MudAppBar>
    <NavMenu />
    <MudMainContent Class="pt-16 px-16">
        @Body
    </MudMainContent>
</MudLayout>