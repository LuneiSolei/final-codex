@using FinalCodex.Shared
@using MudBlazor
@inherits LayoutComponentBase
@inject AppState AppState
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@AppState.IsDarkMode"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Fixed="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(AppState.ToggleNavMenu)"/>
        <MudSpacer/>
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit"/>
    </MudAppBar>
    
    <MudDrawer @bind-Open="@AppState.IsNavMenuOpen" Variant="DrawerVariant.Mini" OpenMiniOnHover="true" 
               ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">FinalCodex</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.House">Home</MudNavLink>
            <MudNavGroup Title="Account" Expanded="false" Icon="@Icons.Material.Filled.Person">
                <MudNavLink Href="/account/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
                <MudNavLink Href="/account/login" Icon="@Icons.Material.Filled.Login">Log In</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-16">
        @Body
    </MudMainContent>
</MudLayout>





@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
        AppState.OnUpdate += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnUpdate += StateHasChanged;
    }

}