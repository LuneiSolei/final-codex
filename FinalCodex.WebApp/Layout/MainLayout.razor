@using FinalCodex.Shared
@using MudBlazor
@inherits LayoutComponentBase
@inject AppState AppState
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@AppState.IsDarkMode"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudDrawerContainer>
    <MudDrawer @bind-Open="@AppState.IsNavMenuOpen">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">FinalCodex</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/">Home</MudNavLink>
            <MudNavGroup Title="Account" Expanded="false">
                <MudNavLink Href="/account/settings">Settings</MudNavLink>
                <MudNavLink Href="/account/login">Log In</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>
    
    <MudAppBar Fixed="false">
        <MudIconButton
            Icon="@Icons.Material.Filled.Menu"
            Color="Color.Inherit"
            Edge="Edge.Start"
            OnClick="@(AppState.ToggleNavMenu)"/>
        <MudSpacer/>
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit"/>
    </MudAppBar>
    <div>
        @Body
    </div>
</MudDrawerContainer>

@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
        AppState.OnUpdate += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnUpdate += StateHasChanged;
    }

}