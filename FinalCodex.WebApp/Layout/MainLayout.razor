@using FinalCodex.Shared
@using MudBlazor
@inherits LayoutComponentBase
@inject AppState AppState
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@AppState.IsDarkMode"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Fixed="false">
        <MudSpacer />
        <MudSwitch @bind-Value="AppState.IsDarkMode" 
                   ThumbIcon="@(AppState.IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)"
                   Class="@DarkToggleColor()"
                   Color="Color.Primary" 
                   Size="Size.Large"/>
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit" Edge="Edge.End" />
    </MudAppBar>
    
    <MudDrawer @bind-Open="@AppState.IsNavMenuOpen" Variant="DrawerVariant.Mini" ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudIconButton Edge="Edge.Start" Size="Size.Large" Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="@(AppState.ToggleNavMenu)" />
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.House">Home</MudNavLink>
            <MudNavGroup Title="Account" Expanded="false" Icon="@Icons.Material.Filled.Person">
                <MudNavLink Href="/account/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
                <MudNavLink Href="/account/login" Icon="@Icons.Material.Filled.Login">Log In</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-16">
        @Body
    </MudMainContent>
</MudLayout>

@code {

    private string DarkToggleColor()
    {
        return AppState.IsDarkMode ? "icon-color-light" : "icon-color-dark";
    }
    protected override void OnInitialized()
    {
        base.OnInitialized();
        AppState.OnUpdate += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnUpdate += StateHasChanged;
    }
}