@using FinalCodex.SharedLibrary.Services
@using MudBlazor
@inject CodexService CodexService;

<div class="@IconColor">
    <MudToggleIconButton @bind-Toggled="CodexService.AppState.IsDarkMode"
                         Icon="@Icons.Material.TwoTone.LightMode"
                         ToggledIcon="@Icons.Material.TwoTone.DarkMode"
                         title="@(CodexService.AppState.IsDarkMode ? "Dark" : "Light")" />
</div>
