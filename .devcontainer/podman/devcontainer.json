{
    "name": "FinalCodex DevContainer",
    "image": "mcr.microsoft.com/devcontainers/dotnet",
    "forwardPorts": [8443],
    "initializeCommand": "gpg --export > /tmp/pubkeys.gpg",
    "postCreateCommand": "gpg --import /tmp/pubkeys.gpg && rm /tmp/pubkeys.gpg",
    "postAttachCommand": "dotnet restore",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,options=Z",
    "mounts": [
        "source=${localEnv:XDG_RUNTIME_DIR}/gnupg/S.gpg-agent,target=${localEnv:XDG_RUNTIME_DIR}/gnupg/S.gpg-agent,type=bind,options=z",
        "source=/tmp/pubkeys.gpg,target=/tmp/pubkeys.gpg,type=bind"
    ],
    "runArgs": [
        "--userns=keep-id:uid=1000,gid=1000"
    ],
    "customizations": {
        "jetbrains": {
            "settings": {
                "com.intellij:app:Vcs-Log-App-Settings.show_changes_from_parents": true,
                "Git4Idea:app:Git-Application-Settings.use_credential_helper": true,
                "com.intellij:app:HttpConfigurable.use_proxy_pac": true,
                "JavaScript:app:JSEditorOptions.automatically_replace_with_template_string_on_typing": false,
                "JavaScript:app:JSEditorOptions.escape_pasted_text": false,
                "JavaScript:app:JSEditorOptions.close_html_single_tags": false,
                "JavaScript:app:JSEditorOptions.convert_html_to_react": false,
                "JavaScript:app:JSEditorOptions.escape_doc_on_copy_paste": false
            }
        }
    }
}